---
import "@/styles/global.css"
import { ModeToggle } from "@/components/ModeToggle"

interface Props {
  title?: string
  description?: string
  /** Navigation links shown in the top bar */
  navLinks?: Array<{ href: string; label: string }>
  /** App name shown in the top bar */
  appName?: string
}

const {
  title = "Simen starter",
  description = "",
  navLinks = [],
  appName = "App",
} = Astro.props

const pathname = Astro.url.pathname

function isActive(href: string) {
  return pathname === href || pathname.startsWith(href + "/")
}
---

<html lang="nb">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      /* Prevent flash of wrong theme — runs before first paint */
      const getThemePreference = () => {
        if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
          return localStorage.getItem("theme")
        }
        return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"
      }
      const isDark = getThemePreference() === "dark"
      document.documentElement.classList[isDark ? "add" : "remove"]("dark")
    </script>
  </head>
  <body class="min-h-svh flex flex-col">

    <header class="sticky top-0 z-10 border-b border-border bg-card">
      <div class="mx-auto flex h-14 max-w-5xl items-center justify-between px-4 sm:px-6">
        <a
          href="/"
          class="text-sm font-semibold tracking-tight text-foreground hover:text-primary transition-colors"
        >
          {appName}
        </a>
        <nav class="flex items-center gap-1">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                "rounded-md px-3 py-1.5 text-sm font-medium transition-colors",
                isActive(link.href)
                  ? "bg-muted text-foreground"
                  : "text-muted-foreground hover:text-foreground hover:bg-muted/60"
              ]}
            >
              {link.label}
            </a>
          ))}
          <ModeToggle client:load />
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-border/60 py-4">
      <div class="mx-auto max-w-5xl px-4 sm:px-6">
        <p class="text-xs text-muted-foreground/60">
          Et av flere prosjekter{" "}
          <a href="https://simenlager.no/" class="underline hover:text-muted-foreground">
            Simen lager
          </a>.
        </p>
      </div>
    </footer>

  </body>
</html>
